@model IEnumerable<CyfrowaBiblioteka.Models.Ksiazka>

@{
    ViewData["Title"] = "Książki";
}

<h1 class="mb-4">Katalog Książek</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Dodaj nową książkę</a>
</p>

<form asp-controller="Ksiazki" asp-action="Index" method="get" class="mb-4 p-3 bg-light rounded shadow-sm">
    <div class="row align-items-center">
        <div class="col-auto">
            <label class="col-form-label fw-bold">Filtruj po autorze:</label>
        </div>
        <div class="col-auto">
            <select name="searchAutor" asp-items='(SelectList)ViewData["searchAutor"]' class="form-select">
                <option value="">Wszyscy</option>
            </select>
        </div>
        <div class="col-auto">
            <label class="col-form-label fw-bold">Szukaj tytułu:</label>
        </div>
        <div class="col-auto">
            <input type="text" name="searchString" class="form-control" placeholder="Wpisz tytuł..." />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-success">Szukaj</button>
            <a asp-action="Index" class="btn btn-secondary">Wyczyść</a>
        </div>
    </div>
</form>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Tytul)</th>
                <th>@Html.DisplayNameFor(model => model.RokWydania)</th>
                <th>@Html.DisplayNameFor(model => model.Gatunek)</th>
                <th>@Html.DisplayNameFor(model => model.Autor)</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td class="fw-bold">@Html.DisplayFor(modelItem => item.Tytul)</td>
                <td>@Html.DisplayFor(modelItem => item.RokWydania)</td>
                <td>@Html.DisplayFor(modelItem => item.Gatunek)</td>
                <td>@Html.DisplayFor(modelItem => item.Autor.PelneImie)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Szczegóły</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>