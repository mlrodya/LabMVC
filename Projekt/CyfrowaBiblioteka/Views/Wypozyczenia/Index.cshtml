@model IEnumerable<CyfrowaBiblioteka.Models.Wypozyczenie>

@{
    ViewData["Title"] = "Wypożyczenia";
}

<h1 class="mb-4">Historia Wypożyczeń</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nowe Wypożyczenie</a>
</p>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.OsobaWypozyczajaca)</th>
                <th>@Html.DisplayNameFor(model => model.DataWypozyczenia)</th>
                <th>@Html.DisplayNameFor(model => model.DataZwrotu)</th>
                <th>@Html.DisplayNameFor(model => model.Ksiazka)</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td class="fw-bold">@Html.DisplayFor(modelItem => item.OsobaWypozyczajaca)</td>
                <td>@item.DataWypozyczenia.ToShortDateString()</td>
                <td>@(item.DataZwrotu.HasValue ? item.DataZwrotu.Value.ToShortDateString() : "Brak zwrotu")</td>
                <td>@Html.DisplayFor(modelItem => item.Ksiazka.Tytul)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Szczegóły</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>